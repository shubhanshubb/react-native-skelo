{
  "name": "react-native-skelo",
  "version": "0.1.0",
  "description": "Automatic skeleton loading for React Native. Write your UI once, Skelo builds the loading state automatically.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "prepare": "bob build",
    "release": "release-it",
    "clean": "del-cli lib"
  },
  "keywords": [
    "react-native",
    "skeleton",
    "loading",
    "placeholder",
    "shimmer",
    "skeleton-screen",
    "skeleton-loader",
    "loading-state",
    "reanimated",
    "fabric",
    "automatic",
    "zero-config"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shubhanshubb/react-native-skelo.git"
  },
  "author": "Shubhanshu <https://shubhanshubb.dev>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shubhanshubb/react-native-skelo/issues"
  },
  "homepage": "https://github.com/shubhanshubb/react-native-skelo#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3.0.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^18.4.3",
    "@react-native/eslint-config": "^0.73.1",
    "@release-it/conventional-changelog": "^8.0.1",
    "@testing-library/react-native": "^12.4.2",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.45",
    "del-cli": "^5.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "react": "18.2.0",
    "react-native": "0.73.1",
    "react-native-builder-bob": "^0.23.2",
    "react-native-reanimated": "^3.6.1",
    "react-test-renderer": "18.2.0",
    "release-it": "^17.0.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/index.ts",
      "!src/types/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 100,
    "arrowParens": "avoid"
  }
}
